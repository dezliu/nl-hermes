# 国内镜像加速配置
# 用法：在 .env 中设置 USE_CN_MIRROR=1，Makefile 会自动加载本文件
#
# 说明：
# - npm/pip/apt 走国内源（构建阶段加速）
# - Docker Hub 基础镜像（node/python/mysql 等）请配合 make mirror-daemon 配置守护进程加速
# - 勿在 PYTHON_IMAGE/NODE_IMAGE 写带前缀的代理地址，BuildKit 易遇 401；用官方名 + daemon 镜像即可
# - 若 daemon 未配置，可取消下方 *_IMAGE 注释，改用 docker.1ms.run 前缀（比 daocloud 更稳）

USE_CN_MIRROR=1

# 可选：仅当未配置 daemon registry-mirrors 时启用（取消注释）
# MYSQL_IMAGE=docker.1ms.run/library/mysql:8.0
# REDIS_IMAGE=docker.1ms.run/library/redis:7-alpine
# QDRANT_IMAGE=docker.1ms.run/qdrant/qdrant:v1.12.5
# OPENSEARCH_IMAGE=docker.1ms.run/opensearchproject/opensearch:2.18.0
# NGINX_IMAGE=docker.1ms.run/library/nginx:1.27-alpine

# 构建阶段包管理器镜像（始终启用）
NPM_REGISTRY=https://registry.npmmirror.com
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
APK_MIRROR=mirrors.aliyun.com
APT_MIRROR=mirrors.aliyun.com
