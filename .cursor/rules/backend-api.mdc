## 外部调用封装

```typescript
// ❌ 反面：Service 内直接 new 客户端，难以测试与替换
const result = await new QdrantClient({ url: process.env.QDRANT_URL }).search(...);

// ✅ 正面：通过 Port + Adapter，配置注入
export interface VectorSearchPort {
  search(collection: string, vector: number[], opts: SearchOpts): Promise<SearchHit[]>;
}

export class QdrantVectorSearch implements VectorSearchPort {
  constructor(private readonly client: QdrantClient, private readonly logger: Logger) {}
  async search(collection: string, vector: number[], opts: SearchOpts) {
    const start = Date.now();
    try {
      return await this.client.search(collection, { vector, ...opts });
    } catch (err) {
      this.logger.error('qdrant.search.failed', { collection, traceId: opts.traceId, err });
      throw new ExternalServiceError('向量检索失败', { cause: err });
    } finally {
      this.logger.debug('qdrant.search.timing', { collection, ms: Date.now() - start });
    }
  }
}
```

Redis 缓存：key 命名遵循 `{service}:{entity}:{id}` 约定；TTL 来自配置；缓存 miss 时回源 Service，不在 Resolver 操作缓存。

