## Repository 与查询

```typescript
// ❌ 反面：N+1 查询
const items = await ItemModel.query();
for (const item of items) {
  item.owner = await UserModel.query().findById(item.ownerId);
}

// ✅ 正面：eager loading + 列选择
const items = await ItemModel.query()
  .select('id', 'title', 'ownerId', 'updatedAt')
  .withGraphFetched('owner(ownerSelect)')
  .modifiers({ ownerSelect: (q) => q.select('id', 'name') })
  .where('status', 'active')
  .orderBy('updatedAt', 'desc')
  .limit(pageSize)
  .offset(offset);
```

```typescript
// ❌ 反面：字符串拼接 SQL
await Model.knex().raw(`SELECT * FROM items WHERE name = '${name}'`);

// ✅ 正面：参数化查询
await Model.query().where('name', name);
// 或 knex.raw('... WHERE name = ?', [name])
```

