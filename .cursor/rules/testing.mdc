## 单元测试示例

```typescript
// ❌ 反面：测实现细节，断言 mock 调用次数
it('calls schemaSearch', async () => {
  await service.generate(user, input, traceId);
  expect(mockSearch).toHaveBeenCalledTimes(1);
});

// ✅ 正面：测行为与输出
it('should_return_draft_when_prompt_is_valid', async () => {
  mockSearch.mockResolvedValue([{ id: 'schema-1', score: 0.9 }]);
  mockGenerator.mockResolvedValue({ sql: 'SELECT 1', confidence: 0.85 });

  const result = await service.generate(user, { prompt: '销售额' }, traceId);

  expect(result.draft.sql).toBe('SELECT 1');
  expect(result.draft.confidence).toBeGreaterThan(0.8);
});

it('should_throw_forbidden_when_user_lacks_permission', async () => {
  const unauthorizedUser = { ...user, permissions: [] };
  await expect(service.generate(unauthorizedUser, input, traceId))
    .rejects.toThrow(ForbiddenError);
});
```

