## GraphQL 契约测试

```typescript
// ✅ 验证 schema 与 resolver 行为一致
it('should_reject_unauthenticated_generateReport', async () => {
  const { body } = await request(app)
    .post('/graphql')
    .send({ query: GENERATE_REPORT, variables: { input: { prompt: 'test' } } });

  expect(body.errors[0].extensions.code).toBe('UNAUTHENTICATED');
});

it('should_match_generateReport_response_shape', async () => {
  const { body } = await authenticatedRequest(app, user)
    .send({ query: GENERATE_REPORT, variables: { input: validInput } });

  expect(body.data.generateReport).toMatchObject({
    draft: { sql: expect.any(String), confidence: expect.any(Number) },
  });
});
```

